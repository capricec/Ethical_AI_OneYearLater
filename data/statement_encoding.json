    "items": [
      { "item_id": "23_1", "text": "When jobs are scarce, men should have more right to a job than women", "reverse": false, "subscale": "gender_roles" },
      { "item_id": "23_2", "text": "When jobs are scarce, employers should give priority to people of this country over immigrants", "reverse": true, "subscale": "Immigration" },
      { "item_id": "23_3", "text": "If a woman earns more money than her husband, its almost certain to cause problems", "reverse": false, "subscale": "gender_roles" },
      { "item_id": "23_4", "text": "Adult children have the duty to provide long-term care for their parents", "reverse": false, "subscale": "family_obligation" },
      { "item_id": "23_5", "text": "One of my main goals in life has been to make my parents proud", "reverse": false, "subscale": "family_obligation" },
      { "item_id": "23_6", "text": "When a mother works for pay, the children suffer", "reverse": false, "subscale": "gender_roles" },
      { "item_id": "23_7", "text": "On the whole, men make better political leaders than women do", "reverse": false, "subscale": "gender_roles" },
      { "item_id": "23_8", "text": "A university education is more important for a boy than for a girl", "reverse": false, "subscale": "gender_roles" },
      { "item_id": "23_9", "text": "On the whole, men make better business executives than women do", "reverse": false, "subscale": "gender_roles" },
      { "item_id": "23_10", "text": "Being a housewife/homeworker is just as fulfilling as working for pay", "reverse": false, "subscale": "gender_roles" }
    ],
    "coding": "higher = more traditional"
  },
